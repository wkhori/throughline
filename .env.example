# Throughline Weekly Commit Module — env.example
# Copy to `.env.local` and fill before running. `.env.local` is gitignored.
# Continue-and-defer rule: every external dep has a stub. Missing values do
# NOT block the build; stub providers activate automatically. See
# `docs/orchestration-plan.md` and `docs/env-deferred.md`.

# --- Database (Docker provides these; matches docker-compose.yml) -----------
DATABASE_URL=jdbc:postgresql://localhost:5432/throughline
DATABASE_USER=throughline
DATABASE_PASSWORD=throughline

# --- Auth0 (real-integration mode requires these; stub used otherwise) ------
# Stub mode: leave AUTH0_ISSUER_URI unset → MockJwtDecoder activates under
# `dev` profile. Frontend MockAuth0Provider activates when VITE_AUTH0_DOMAIN
# is unset.
AUTH0_ISSUER_URI=
AUTH0_AUDIENCE=https://api.throughline.app
VITE_AUTH0_DOMAIN=
VITE_AUTH0_CLIENT_ID=
VITE_AUTH0_AUDIENCE=https://api.throughline.app

# --- Frontend → backend wiring ---------------------------------------------
VITE_API_BASE_URL=http://localhost:8080
VITE_WEEKLY_COMMIT_REMOTE_URL=http://localhost:5174/remoteEntry.js

# --- Anthropic (Phase 5a — stub used until set) -----------------------------
ANTHROPIC_API_KEY=

# --- Slack notifications (Phase 6 — LogChannel used until set) -------------
SLACK_WEBHOOK_URL=
NOTIFICATION_CHANNEL=log

# --- Org config -------------------------------------------------------------
ORG_TIMEZONE=America/New_York

# --- Backend runtime --------------------------------------------------------
SPRING_PROFILES_ACTIVE=dev
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# --- Optional dev flags -----------------------------------------------------
VITE_DEV_PERSONAS=true
