<?xml version="1.0" encoding="UTF-8"?>
<!--
  SpotBugs filter — Java records that hold immutable List<> fields trip
  EI / EI2 (may expose internal representation). DTOs in this module are
  serialized to JSON and never mutated; the warning is a false positive
  documented at https://github.com/spotbugs/spotbugs/issues/2444.
-->
<FindBugsFilter
    xmlns="https://github.com/spotbugs/filter/3.0.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="https://github.com/spotbugs/filter/3.0.0 https://raw.githubusercontent.com/spotbugs/spotbugs/3.1.0/spotbugs/etc/findbugsfilter.xsd">
  <Match>
    <Class name="~com\.throughline\.weeklycommit\.web\.dto\..+" />
    <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2" />
  </Match>
  <Match>
    <Class name="~com\.throughline\.weeklycommit\.web\.AuthController\$MeDto" />
    <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2" />
  </Match>
</FindBugsFilter>
