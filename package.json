{
  "name": "throughline",
  "private": true,
  "version": "0.1.0",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22.17.1",
    "yarn": ">=1.22.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "lint": "nx run-many -t lint",
    "type-check": "nx run-many -t type-check",
    "test": "nx run-many -t test",
    "build": "nx run-many -t build",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css,html,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css,html,yml,yaml}\"",
    "dev:host": "nx run host:dev",
    "dev:remote": "nx run weekly-commit-remote:dev",
    "dev:api": "cd services/api && ./gradlew bootRun",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "evals": "node evals/runner.ts"
  },
  "devDependencies": {
    "@badeball/cypress-cucumber-preprocessor": "^24.0.1",
    "@bahmutov/cypress-esbuild-preprocessor": "^2.2.8",
    "@nx/eslint": "20.3.0",
    "@nx/js": "20.3.0",
    "@nx/vite": "20.3.0",
    "@types/node": "22.10.2",
    "@typescript-eslint/eslint-plugin": "8.18.0",
    "@typescript-eslint/parser": "8.18.0",
    "cypress": "^15.14.1",
    "eslint": "9.17.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-react": "7.37.2",
    "eslint-plugin-react-hooks": "5.1.0",
    "nx": "20.3.0",
    "prettier": "3.3.3",
    "typescript": "5.7.2"
  },
  "packageManager": "yarn@1.22.22"
}
