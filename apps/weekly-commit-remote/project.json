{
  "name": "weekly-commit-remote",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/weekly-commit-remote/src",
  "projectType": "application",
  "targets": {
    "lint": { "executor": "nx:run-commands", "options": { "command": "eslint .", "cwd": "apps/weekly-commit-remote" } },
    "type-check": { "executor": "nx:run-commands", "options": { "command": "tsc --noEmit", "cwd": "apps/weekly-commit-remote" } },
    "test": { "executor": "nx:run-commands", "options": { "command": "vitest run --coverage", "cwd": "apps/weekly-commit-remote" } },
    "build": { "executor": "nx:run-commands", "options": { "command": "tsc --noEmit && vite build", "cwd": "apps/weekly-commit-remote" } },
    "dev": { "executor": "nx:run-commands", "options": { "command": "vite --port 5174", "cwd": "apps/weekly-commit-remote" } }
  }
}
